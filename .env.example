# --- TELEGRAM ---
# Режим Telethon: 'bot' (по токену бота) или 'user' (по телефону)
AUTH_MODE=bot

# Для Aiogram (ответы в чатах)
TELEGRAM_BOT_TOKEN=xxx:your_token_here

# Для Telethon (нужны и в bot, и в user режимах)
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# --- ВЕКТОРНОЕ ХРАНИЛИЩЕ ---
# chroma (по умолчанию) или astra
VECTOR_BACKEND=chroma

# Chroma (локальная БД)
CHROMA_DIR=./chroma_storage
CHROMA_COLLECTION=news_digest
CHROMA_DISTANCE=cosine

# Astra DB (опционально; используется, если VECTOR_BACKEND=astra)
ASTRA_DB_TOKEN=your_astra_token
ASTRA_DB_ENDPOINT=https://xxxx-xxxx.apps.astra.datastax.com
ASTRA_DB_KEYSPACE=default_keyspace
ASTRA_DB_COLLECTION=news_digest
ASTRA_POSTS_COLLECTION=news_posts

# --- OLLAMA ---
# Рекомендуется qwen2:7b-instruct (LLM) + bge-m3 (эмбеддинги)
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDINGS=mxbai-embed-large:latest
# (вариант быстрее эмбеддингов)
# OLLAMA_EMBEDDINGS=nomic-embed-text

# --- TELEGRAPH ---
TELEGRAPH_SHORT_NAME=NewsDigestBot

# --- МОНИТОРИМ ЭТИ ЧАТЫ/КАНАЛЫ ---
# JSON-словарь: id/username -> категория (auto | real_estate)
# Можно использовать -100<ID_канала>, обычный id, или @username
MONITORED_CHANNELS={"-1003039322382":"real_estate","-1002845950489":"auto"}

# --- АВТОДАЙДЖЕСТЫ (расписание) Опционально
AUTO_DIGEST=true           # включить/выключить автопостинг дайджестов
DIGEST_HOUR=9              # час отправки
TIMEZONE=Europe/Moscow     # таймзона планировщика